# ============================================================
# Stats LIFF - 環境変数テンプレート
# このファイルを .env にコピーして全項目を埋めてからデプロイしてください
# ============================================================

# --- GCP ---
PROJECT_ID="your-gcp-project-id"
REGION="asia-northeast1"
BQ_LOCATION="asia-northeast1"

# --- BigQuery ---
BQ_DATASET_RAW="stats_raw"
BQ_DATASET_MART="stats_mart"

# --- 試験日（dim_dateのdays_until_exam計算に使用）---
EXAM_DATE="2026-07-31"

# --- LINE / LIFF ---
# LINE Developers Console > LINE Login channel > Channel ID
LIFF_CHANNEL_ID="0000000000"
# LIFF設定後に発行されるLIFF ID(例: 1234567890-AbCdEfGh)
LIFF_ID="0000000000-XXXXXXXX"

# --- セキュリティ ---
# user_idのSHA256ハッシュ用ソルト。openssl rand -hex 32 等で生成
USER_ID_SALT="REPLACE_WITH_RANDOM_HEX_32BYTES"

# --- フロントエンドホスティング ---
# Firebase Hostingプロジェクト ID（PROJECT_IDと同じでもOK）
FIREBASE_PROJECT="${PROJECT_ID}"

# --- CORS許可オリジン（フロントのデプロイURL）---
# Firebase Hostingなら https://${PROJECT_ID}.web.app
ALLOWED_ORIGIN="https://your-frontend-domain"
